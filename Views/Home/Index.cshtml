@{
    ViewData["Title"] = "Grand Arbre Consulting";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Grand Arbre Consulting</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        :root {
            --teal-deep: #0F4C5C;
            --teal-soft: #1E6F7F;
            --gold-main: #D4AF37;
            --gold-light: #F2E3B3;
            --white: #FFFFFF;
            --light-bg: #F8FAFC;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
            background: var(--white);
        }

        /* Top Bar with Logo */
        .top-bar {
            background: var(--teal-deep);
            padding: 10px 0;
            border-bottom: 3px solid var(--gold-main);
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1000;
        }

            .top-bar .logo-container {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 12px;
            }

            .top-bar .logo-icon {
                width: 40px;
                height: 40px;
                background: var(--gold-main);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                overflow: hidden;
                flex-shrink: 0;
                box-shadow: 0 2px 10px rgba(212, 175, 55, 0.3);
            }

                .top-bar .logo-icon img {
                    width: 100%;
                    height: 100%;
                    object-fit: cover;
                }

                .top-bar .logo-icon i {
                    font-size: 22px;
                    color: var(--teal-deep);
                }

            .top-bar .logo-text {
                color: var(--white);
                font-size: 1.3rem;
                font-weight: 800;
                letter-spacing: 1px;
                line-height: 1.2;
            }

                .top-bar .logo-text span {
                    color: var(--gold-main);
                }

            .top-bar .logo-tagline {
                color: rgba(255,255,255,0.6);
                font-size: 0.65rem;
                letter-spacing: 2px;
                text-transform: uppercase;
            }

        /* Hero Section */
        .hero {
            background: linear-gradient(135deg, var(--teal-deep) 0%, var(--teal-soft) 100%);
            padding: 120px 0 70px;
            position: relative;
            overflow: hidden;
            min-height: 65vh;
            display: flex;
            align-items: center;
            width: 100%;
            margin-top: 64px;
        }

            .hero::before {
                content: '';
                position: absolute;
                top: -30%;
                right: -10%;
                width: 400px;
                height: 400px;
                background: rgba(212, 175, 55, 0.05);
                border-radius: 50%;
            }

            .hero::after {
                content: '';
                position: absolute;
                bottom: -20%;
                left: -5%;
                width: 250px;
                height: 250px;
                background: rgba(212, 175, 55, 0.03);
                border-radius: 50%;
            }

        .hero-content {
            position: relative;
            z-index: 1;
            width: 100%;
            padding: 0 20px;
        }

        .hero h1 {
            font-size: 3.5rem;
            font-weight: 900;
            color: var(--white);
            margin-bottom: 15px;
            line-height: 1.1;
        }

            .hero h1 span {
                color: var(--gold-main);
            }

        .hero p {
            font-size: 1.1rem;
            color: rgba(255,255,255,0.9);
            max-width: 650px;
            margin: 0 auto;
            line-height: 1.8;
        }

        .hero .hero-description {
            font-size: 0.95rem;
            color: rgba(255,255,255,0.8);
            max-width: 600px;
            margin: 0 auto;
            line-height: 1.8;
        }

        .hero-divider {
            width: 60px;
            height: 3px;
            background: var(--gold-main);
            margin: 18px auto;
            border-radius: 2px;
        }

        .hero-badge {
            display: inline-block;
            background: rgba(212, 175, 55, 0.15);
            color: var(--gold-main);
            padding: 6px 20px;
            border-radius: 30px;
            font-size: 0.8rem;
            font-weight: 600;
            margin-bottom: 18px;
            border: 1px solid rgba(212, 175, 55, 0.2);
        }

        .hero .btn-gold {
            background: var(--gold-main);
            color: var(--teal-deep);
            font-weight: 700;
            border: none;
            padding: 12px 40px;
            font-size: 1rem;
            border-radius: 30px;
            transition: all 0.3s;
        }

            .hero .btn-gold:hover {
                background: #B88A1A;
                color: var(--white);
                transform: translateY(-3px);
                box-shadow: 0 10px 30px rgba(212, 175, 55, 0.3);
            }

        .hero .btn-outline-gold {
            background: transparent;
            border: 2px solid var(--gold-main);
            color: var(--gold-main);
            font-weight: 700;
            padding: 10px 35px;
            font-size: 1rem;
            border-radius: 30px;
            transition: all 0.3s;
        }

            .hero .btn-outline-gold:hover {
                background: var(--gold-main);
                color: var(--teal-deep);
                transform: translateY(-3px);
            }

        /* Login Cards */
        .login-section {
            padding: 60px 0;
            background: var(--light-bg);
        }

        .login-card {
            background: var(--white);
            border-radius: 16px;
            padding: 35px 25px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.06);
            transition: all 0.3s;
            height: 100%;
            border: 1px solid #f0f0f0;
            text-align: center;
        }

            .login-card:hover {
                transform: translateY(-10px);
                box-shadow: 0 15px 40px rgba(15, 76, 92, 0.1);
                border-color: var(--gold-main);
            }

            .login-card .icon {
                width: 70px;
                height: 70px;
                background: rgba(212, 175, 55, 0.1);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 18px;
            }

                .login-card .icon i {
                    font-size: 30px;
                    color: var(--gold-main);
                }

            .login-card h4 {
                font-weight: 700;
                color: var(--teal-deep);
                margin-bottom: 10px;
                font-size: 1.2rem;
            }

            .login-card p {
                color: #6B7A8A;
                font-size: 0.9rem;
                line-height: 1.7;
                margin-bottom: 18px;
            }

            .login-card .btn {
                width: 100%;
                padding: 10px;
                border-radius: 10px;
                font-weight: 600;
                font-size: 0.95rem;
            }

            .login-card .btn-user {
                background: var(--gold-main);
                color: var(--teal-deep);
            }

                .login-card .btn-user:hover {
                    background: #B88A1A;
                    color: white;
                }

            .login-card .btn-admin {
                background: var(--teal-deep);
                color: white;
            }

                .login-card .btn-admin:hover {
                    background: #0A3A48;
                    color: var(--gold-main);
                }

            .login-card .badge-role {
                display: inline-block;
                background: rgba(212, 175, 55, 0.1);
                color: var(--gold-main);
                padding: 4px 12px;
                border-radius: 20px;
                font-size: 0.65rem;
                font-weight: 600;
                margin-bottom: 12px;
            }

        /* Footer */
        footer {
            background: #0A3A48;
            color: rgba(255,255,255,0.8);
            padding: 50px 0 20px;
        }

            footer h5 {
                color: var(--white);
                font-weight: 700;
                margin-bottom: 20px;
                font-size: 1.1rem;
            }

                footer h5 i {
                    color: var(--gold-main);
                    margin-right: 10px;
                }

            footer a {
                color: rgba(255,255,255,0.7);
                text-decoration: none;
                transition: all 0.3s;
            }

                footer a:hover {
                    color: var(--gold-main);
                }

            footer .footer-links {
                list-style: none;
                padding: 0;
            }

                footer .footer-links li {
                    padding: 6px 0;
                    font-size: 0.9rem;
                }

                    footer .footer-links li i {
                        color: var(--gold-main);
                        margin-right: 10px;
                        font-size: 10px;
                    }

            footer .social-icons a {
                display: inline-block;
                width: 35px;
                height: 35px;
                background: rgba(255,255,255,0.05);
                border-radius: 50%;
                text-align: center;
                line-height: 35px;
                margin-right: 8px;
                transition: all 0.3s;
                color: rgba(255,255,255,0.7);
            }

                footer .social-icons a:hover {
                    background: var(--gold-main);
                    color: var(--teal-deep);
                    transform: translateY(-3px);
                }

            footer .footer-bottom {
                border-top: 1px solid rgba(255,255,255,0.1);
                padding-top: 20px;
                margin-top: 30px;
                text-align: center;
                font-size: 0.85rem;
            }

        /* Responsive */
        @@media (max-width: 992px) {
            .hero {
                min-height: 55vh;
                padding: 110px 0 50px;
            }

                .hero h1 {
                    font-size: 2.8rem;
                }

                .hero p {
                    font-size: 1rem;
                    max-width: 90%;
                }

            .top-bar .logo-text {
                font-size: 1.1rem;
            }

            .top-bar .logo-tagline {
                display: none;
            }

            .top-bar .logo-icon {
                width: 35px;
                height: 35px;
            }
        }

        @@media (max-width: 768px) {
            .hero {
                min-height: 45vh;
                padding: 90px 0 40px;
            }

                .hero h1 {
                    font-size: 2rem;
                }

            .hero-content {
                padding: 0 15px;
            }

            .hero .btn-gold, .hero .btn-outline-gold {
                padding: 10px 30px;
                font-size: 0.9rem;
            }

            .hero .hero-description {
                font-size: 0.85rem;
            }

            .login-card {
                margin-bottom: 20px;
            }

            .top-bar .logo-icon {
                width: 30px;
                height: 30px;
            }

            .top-bar .logo-text {
                font-size: 0.9rem;
            }

            .top-bar .logo-tagline {
                display: none;
            }

            .top-bar .logo-container {
                gap: 8px;
            }
        }

        @@media (max-width: 576px) {
            .hero {
                min-height: 40vh;
                padding: 80px 0 30px;
            }

                .hero h1 {
                    font-size: 1.6rem;
                }

            .hero-badge {
                font-size: 0.65rem;
                padding: 4px 14px;
            }

            .hero p {
                font-size: 0.85rem;
            }

            .top-bar .logo-text {
                font-size: 0.75rem;
            }

            .top-bar .logo-icon {
                width: 28px;
                height: 28px;
            }

            .top-bar {
                padding: 8px 0;
            }

            .login-section {
                padding: 40px 0;
            }

            .login-card {
                padding: 25px 20px;
            }
        }
    </style>
</head>
<body>
    <!-- Top Bar with Logo -->
    <div class="top-bar">
        <div class="container">
            <div class="logo-container">
                <div class="logo-icon">
                    <img src="/images/GAC Logo copy 2 (1).png" alt="GAC LOGO" />
                </div>
                <div>
                    <div class="logo-text">GRAND ARBRE <span>CONSULTING</span></div>
                    <div class="logo-tagline">Alive. Inspired. Motivated.</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Hero Section -->
    <section class="hero" id="hero">
        <div class="container-fluid hero-content">
            <div class="row align-items-center justify-content-center">
                <div class="col-lg-8 col-xl-6 text-center">
                    <div class="hero-badge">
                        <i class="fas fa-star"></i> EST. 2017
                    </div>
                    <h1>Alive. Inspired. <br><span>Motivated</span></h1>
                    <p>Audit, Compliance, Tender Support &amp; Virtual Administration for SMMEs</p>
                    <div class="hero-divider"></div>
                    <p class="hero-description">
                        Established in 2017, we help Small, Medium and Micro Enterprises operate with confidence,
                        credibility, and consistency through integrated compliance and administration solutions.
                    </p>
                    <div class="mt-4 d-flex flex-wrap gap-3 justify-content-center">
                        <a href="#login" class="btn btn-gold">Get Started</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Login Section -->
    <section class="login-section" id="login">
        <div class="container">
            <div class="text-center mb-5">
                <h2 style="font-weight: 800; color: var(--teal-deep);">Access Your <span style="color: var(--gold-main);">Account</span></h2>
                <div style="width: 80px; height: 4px; background: var(--gold-main); margin: 15px auto; border-radius: 2px;"></div>
                <p style="color: #6B7A8A; max-width: 600px; margin: 0 auto;">Choose your login option below</p>
            </div>
            <div class="row justify-content-center">
                <!-- User Login Card -->
                <div class="col-md-5 mb-4">
                    <div class="login-card">
                        <div class="icon">
                            <i class="fas fa-user"></i>
                        </div>
                        <span class="badge-role">Employees &amp; Clients</span>
                        <h4>User Login</h4>
                        <p>Sign in with your email address and access code provided by your administrator.</p>
                        <a href="/Account/UserLogin" class="btn btn-user">
                            <i class="fas fa-sign-in-alt"></i> Sign In as User
                        </a>
                    </div>
                </div>

                <!-- Admin Login Card -->
                <div class="col-md-5 mb-4">
                    <div class="login-card">
                        <div class="icon">
                            <i class="fas fa-user-shield"></i>
                        </div>
                        <span class="badge-role">Administrators</span>
                        <h4>Admin Login</h4>
                        <p>Secure access for system administrators with full management capabilities.</p>
                        <a href="/Account/AdminLogin" class="btn btn-admin">
                            <i class="fas fa-shield-alt"></i> Sign In as Admin
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

  

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>