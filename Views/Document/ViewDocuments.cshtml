@model List<Grand_Arbre_portal.Models.Document>
@{
    ViewData["Title"] = "Document Dashboard";
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
    var selectedCategory = ViewBag.SelectedCategory as string ?? "All";
}

<div class="container-fluid mt-4">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center flex-wrap">
                <div>
                    <h2 class="fw-bold" style="color: #0F4C5C;">
                        <i class="fas fa-folder-open" style="color: #D4AF37;"></i> Document Dashboard
                    </h2>
                    <p class="text-muted">Manage all your documents in one place</p>
                </div>
                <div class="d-flex gap-2">
                    <div class="input-group" style="width: 250px;">
                        <input type="text" id="searchInput" class="form-control" placeholder="Search documents..." />
                        <button class="btn btn-gold" type="button">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                    @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
                    {
                        <a href="/Document/Upload" class="btn btn-gold">
                            <i class="fas fa-upload"></i> Upload
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Stats -->
    <div class="row mb-4">
        <div class="col-md-3 col-6 mb-2">
            <div class="card text-center border-0 shadow-sm">
                <div class="card-body py-3">
                    <h5 class="text-primary fw-bold">@Model.Count</h5>
                    <p class="text-muted mb-0">Total</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6 mb-2">
            <div class="card text-center border-0 shadow-sm">
                <div class="card-body py-3">
                    <h5 class="text-success fw-bold">@Model.Where(d => d.Status == "Active").Count()</h5>
                    <p class="text-muted mb-0">Active</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6 mb-2">
            <div class="card text-center border-0 shadow-sm">
                <div class="card-body py-3">
                    <h5 class="text-warning fw-bold">@Model.Where(d => d.Status == "Pending").Count()</h5>
                    <p class="text-muted mb-0">Pending</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6 mb-2">
            <div class="card text-center border-0 shadow-sm">
                <div class="card-body py-3">
                    <h5 class="text-danger fw-bold">@Model.Where(d => d.Status == "Expired").Count()</h5>
                    <p class="text-muted mb-0">Expired</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Navigation Breadcrumb -->
    <div class="row mb-3">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item active" id="breadcrumbAll" onclick="showAll()" style="cursor: pointer;">
                        <i class="fas fa-folder-open"></i> All Documents
                    </li>
                    <li class="breadcrumb-item" id="breadcrumbCategory" style="display: none;">
                        <span id="currentCategoryName"></span>
                    </li>
                </ol>
            </nav>
        </div>
    </div>

    <!-- Folder View -->
    <div class="row mb-4" id="folderView">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="mb-0"><i class="fas fa-folder"></i> Document Categories</h5>
                        <button class="btn btn-sm btn-gold" onclick="showAll()">
                            <i class="fas fa-th-list"></i> Show All
                        </button>
                    </div>
                    <div class="row" id="folderContainer">
                        @{
                            var categories = new Dictionary<string, string>
                                                {
                                                {"CIPC", "CIPC Registration"},
                                                {"Tax", "Tax Clearance"},
                                                {"BBBEE", "BBBEE Certificate"},
                                                {"CSD", "CSD Registration"},
                                                {"CIDB", "CIDB Registration"},
                                                {"Profile", "Business Profile"},
                                                {"Financial", "Financial Documents"},
                                                {"Branding", "Branding"},
                                                {"Share", "Share Certificate"},
                                                {"Other", "Other Documents"}
                                                };
                            var categoryIcons = new Dictionary<string, string>
                                                {
                                                {"CIPC", "fa-file-contract"},
                                                {"Tax", "fa-file-invoice"},
                                                {"BBBEE", "fa-certificate"},
                                                {"CSD", "fa-registered"},
                                                {"CIDB", "fa-hard-hat"},
                                                {"Profile", "fa-building"},
                                                {"Financial", "fa-money-bill-wave"},
                                                {"Branding", "fa-paint-brush"},
                                                {"Share", "fa-file-signature"},
                                                {"Other", "fa-folder"}
                                                };
                        }
                        @foreach (var cat in categories)
                        {
                            var count = Model.Count(d => d.Category == cat.Key);
                            var icon = categoryIcons.ContainsKey(cat.Key) ? categoryIcons[cat.Key] : "fa-folder";
                            <div class="col-lg-2 col-md-3 col-4 mb-3 folder-item" onclick="openFolder('@cat.Key')">
                                <div class="folder-card text-center">
                                    <div class="folder-icon">
                                        <i class="fas @icon" style="font-size: 48px; color: #D4AF37;"></i>
                                    </div>
                                    <div class="folder-name">@cat.Value</div>
                                    <div class="folder-count">@count documents</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Document List -->
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-0">
                    <div id="documentList">
                        @if (!Model.Any())
                        {
                            <div class="text-center py-5">
                                <i class="fas fa-folder-open" style="font-size: 64px; color: #ddd;"></i>
                                <h4 class="mt-3">No Documents Found</h4>
                                <p class="text-muted">Upload your first document to get started</p>
                                @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
                                {
                                    <a href="/Document/Upload" class="btn btn-gold">Upload Document</a>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="list-group list-group-flush" id="documentsContainer">
                                @foreach (var doc in Model.OrderByDescending(d => d.UploadedAt))
                                {
                                    var category = !string.IsNullOrEmpty(doc.Category) ? doc.Category : "Other";
                                    var icon = GetFileIcon(doc.FileName);
                                    var statusClass = doc.Status == "Active" ? "text-success" : (doc.Status == "Pending" ? "text-warning" : "text-danger");
                                    var statusIcon = doc.Status == "Active" ? "fa-check-circle" : (doc.Status == "Pending" ? "fa-clock" : "fa-exclamation-circle");

                                    <div class="list-group-item document-item" data-category="@category" data-search="@doc.Title @doc.Description @doc.UploadedByUserName">
                                        <div class="d-flex align-items-center">
                                            <!-- Document Icon -->
                                            <div class="document-icon me-3">
                                                <i class="fas @icon" style="font-size: 28px;"></i>
                                            </div>

                                            <!-- Document Info -->
                                            <div class="flex-grow-1">
                                                <div class="d-flex flex-wrap align-items-center gap-2">
                                                    <h6 class="mb-0 fw-bold document-title">@doc.Title</h6>
                                                    <span class="badge bg-secondary">@category</span>
                                                    @if (doc.Status == "Active")
                                                    {
                                                        <span class="badge bg-success"><i class="fas fa-check-circle"></i> Active</span>
                                                    }
                                                    else if (doc.Status == "Pending")
                                                    {
                                                        <span class="badge bg-warning"><i class="fas fa-clock"></i> Pending</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-danger"><i class="fas fa-exclamation-circle"></i> Expired</span>
                                                    }
                                                </div>
                                                <div class="document-meta mt-1">
                                                    <small class="text-muted">
                                                        <i class="fas fa-user"></i> @doc.UploadedByUserName
                                                        <i class="fas fa-calendar-alt ms-2"></i> @doc.UploadedAt.ToString("MMM dd, yyyy")
                                                        <i class="fas fa-download ms-2"></i> @doc.DownloadCount downloads
                                                    </small>
                                                </div>
                                                @if (!string.IsNullOrEmpty(doc.Description))
                                                {
                                                    <p class="document-description mt-1">@doc.Description</p>
                                                }
                                                @if (doc.ExpiryDate != null)
                                                {
                                                    <small class="text-danger">
                                                        <i class="fas fa-exclamation-triangle"></i> Expires: @doc.ExpiryDate.Value.ToString("MMM dd, yyyy")
                                                        @if (doc.ExpiryDate.Value < DateTime.Now)
                                                        {
                                                            <span class="text-danger fw-bold"> (EXPIRED)</span>
                                                        }
                                                    </small>
                                                }
                                            </div>

                                            <!-- Actions -->
                                            <div class="document-actions ms-2">
                                                <a href="/Document/Download/@doc.Id" class="btn btn-sm btn-gold" title="Download">
                                                    <i class="fas fa-download"></i>
                                                </a>
                                                @if (User.IsInRole("Admin") || doc.UploadedByUserId == currentUserId)
                                                {
                                                    <button onclick="deleteDoc(@doc.Id)" class="btn btn-sm btn-danger" title="Delete">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    public string GetFileIcon(string fileName)
    {
        var ext = System.IO.Path.GetExtension(fileName)?.ToLower();
        return ext switch
        {
            ".pdf" => "fa-file-pdf text-danger",
            ".doc" or ".docx" => "fa-file-word text-primary",
            ".xls" or ".xlsx" => "fa-file-excel text-success",
            ".ppt" or ".pptx" => "fa-file-powerpoint text-warning",
            ".jpg" or ".jpeg" or ".png" or ".gif" or ".bmp" => "fa-file-image text-info",
            ".zip" or ".rar" or ".7z" => "fa-file-archive text-secondary",
            ".txt" => "fa-file-alt text-secondary",
            _ => "fa-file text-secondary"
        };
    }
}

<style>
    /* Folder Styles */
    .folder-card {
        padding: 20px 10px;
        border-radius: 16px;
        cursor: pointer;
        transition: all 0.3s;
        background: #f8f9fa;
        border: 3px solid transparent;
        height: 100%;
        min-height: 130px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

        .folder-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 35px rgba(0,0,0,0.12);
            border-color: #D4AF37;
            background: white;
        }

        .folder-card.active {
            border-color: #D4AF37;
            background: white;
            box-shadow: 0 8px 25px rgba(212, 175, 55, 0.2);
        }

    .folder-icon {
        font-size: 48px;
        margin-bottom: 10px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
    }

    .folder-name {
        font-size: 0.85rem;
        font-weight: 600;
        color: #0F4C5C;
        margin-bottom: 4px;
        text-align: center;
        line-height: 1.2;
    }

    .folder-count {
        font-size: 0.7rem;
        color: #6c757d;
        font-weight: 500;
    }

    /* Document Item Styles */
    .document-item {
        transition: all 0.2s;
        border-left: 4px solid transparent;
        padding: 15px 20px;
        cursor: default;
    }

        .document-item:hover {
            background: #f8f9fa;
            border-left-color: #D4AF37;
        }

        .document-item .document-title {
            color: #0F4C5C;
            transition: all 0.2s;
        }

        .document-item:hover .document-title {
            color: #D4AF37;
        }

    .document-icon {
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f8f9fa;
        border-radius: 10px;
        flex-shrink: 0;
        border: 1px solid #e8ecf0;
    }

        .document-icon i {
            font-size: 28px;
        }

    .document-meta {
        font-size: 0.8rem;
    }

    .document-description {
        font-size: 0.85rem;
        color: #6c757d;
        margin-bottom: 0;
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .document-actions {
        display: flex;
        gap: 5px;
        flex-shrink: 0;
    }

    .btn-gold {
        background: #D4AF37;
        color: #0F4C5C;
        font-weight: bold;
        border: none;
        transition: all 0.3s;
    }

        .btn-gold:hover {
            background: #B88A1A;
            color: white;
            transform: translateY(-2px);
        }

    .btn-sm {
        padding: 4px 10px;
        border-radius: 5px;
    }

    .badge {
        font-size: 0.7rem;
        padding: 4px 10px;
        border-radius: 20px;
    }

    .card {
        border-radius: 12px;
    }

    .breadcrumb {
        background: white;
        padding: 12px 20px;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        margin: 0;
    }

    .breadcrumb-item {
        font-size: 0.95rem;
    }

        .breadcrumb-item a {
            color: #D4AF37;
            text-decoration: none;
        }

            .breadcrumb-item a:hover {
                text-decoration: underline;
            }

    /* Responsive */
    @@media (max-width: 992px) {
        .folder-icon {
            font-size: 40px;
            height: 50px;
        }

        .folder-card {
            min-height: 110px;
            padding: 15px 8px;
        }

        .folder-name {
            font-size: 0.75rem;
        }
    }

    @@media (max-width: 768px) {
        .document-item .d-flex {
            flex-wrap: wrap;
        }

        .document-actions {
            margin-top: 10px;
            width: 100%;
            justify-content: flex-end;
        }

        .document-item {
            padding: 12px 15px;
        }

        .document-icon {
            width: 40px;
            height: 40px;
        }

            .document-icon i {
                font-size: 22px;
            }

        .folder-icon {
            font-size: 32px;
            height: 40px;
        }

        .folder-card {
            min-height: 90px;
            padding: 12px 5px;
        }

        .folder-name {
            font-size: 0.65rem;
        }
    }
</style>

@section Scripts {
    <script>
        var currentCategory = null;
        var allItems = document.querySelectorAll('.document-item');
        var folderItems = document.querySelectorAll('.folder-item');
        var breadcrumbAll = document.getElementById('breadcrumbAll');
        var breadcrumbCategory = document.getElementById('breadcrumbCategory');
        var currentCategoryName = document.getElementById('currentCategoryName');
        var folderView = document.getElementById('folderView');

        // Open folder function - called when clicking a folder
        function openFolder(category) {
            currentCategory = category;

            // Update breadcrumb
            breadcrumbAll.style.display = 'inline';
            breadcrumbCategory.style.display = 'inline';

            // Get folder name
            var folderCards = document.querySelectorAll('.folder-card');
            var folderName = '';
            folderCards.forEach(function(card) {
                var parent = card.closest('.folder-item');
                if (parent && parent.getAttribute('onclick') && parent.getAttribute('onclick').includes(category)) {
                    folderName = card.querySelector('.folder-name').textContent;
                }
            });
            currentCategoryName.textContent = folderName;

            // Highlight folder
            folderItems.forEach(function(folder) {
                folder.querySelector('.folder-card').classList.remove('active');
            });
            var clickedFolder = document.querySelector('.folder-item[onclick*="' + category + '"]');
            if (clickedFolder) {
                clickedFolder.querySelector('.folder-card').classList.add('active');
            }

            // Filter documents
            var visibleCount = 0;
            allItems.forEach(function(item) {
                var cat = item.getAttribute('data-category');
                if (cat === category) {
                    item.style.display = '';
                    visibleCount++;
                } else {
                    item.style.display = 'none';
                }
            });

            // Show/hide folder view
            folderView.style.display = 'none';

            // Show message if no documents
            var listContainer = document.getElementById('documentList');
            var existingMsg = listContainer.querySelector('.no-docs-msg');
            if (visibleCount === 0) {
                if (!existingMsg) {
                    var msg = document.createElement('div');
                    msg.className = 'text-center py-4 no-docs-msg';
                    msg.innerHTML = '<i class="fas fa-folder-open" style="font-size: 48px; color: #ddd;"></i><p class="mt-2 text-muted">No documents in "' + folderName + '" folder</p>';
                    listContainer.appendChild(msg);
                }
            } else {
                if (existingMsg) {
                    existingMsg.remove();
                }
            }

            // Scroll to document list
            document.getElementById('documentList').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        // Show all documents (back to folder view)
        function showAll() {
            currentCategory = null;

            // Update breadcrumb
            breadcrumbAll.style.display = 'inline';
            breadcrumbCategory.style.display = 'none';

            // Remove folder highlights
            folderItems.forEach(function(folder) {
                folder.querySelector('.folder-card').classList.remove('active');
            });

            // Show all documents
            allItems.forEach(function(item) {
                item.style.display = '';
            });

            // Show folder view
            folderView.style.display = 'block';

            // Remove no docs message
            var listContainer = document.getElementById('documentList');
            var existingMsg = listContainer.querySelector('.no-docs-msg');
            if (existingMsg) {
                existingMsg.remove();
            }

            // Scroll to folder view
            folderView.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        // Breadcrumb click to go back
        document.getElementById('breadcrumbAll').addEventListener('click', function() {
            showAll();
        });

        // Search functionality
        document.getElementById('searchInput').addEventListener('keyup', function() {
            var search = this.value.toLowerCase();
            var items = document.querySelectorAll('.document-item');

            // If searching, show all items and filter
            if (search.length > 0) {
                // Temporarily show all items for search
                items.forEach(function(item) {
                    var text = item.getAttribute('data-search') || item.innerText.toLowerCase();
                    if (text.includes(search)) {
                        item.style.display = '';
                    } else {
                        item.style.display = 'none';
                    }
                });
            } else if (currentCategory) {
                // If no search and we're in a folder, show folder contents
                openFolder(currentCategory);
            } else {
                // If no search and not in a folder, show all
                showAll();
            }
        });

        // Delete document
        function deleteDoc(id) {
            if (confirm('Are you sure you want to delete this document?')) {
                fetch('/Document/DeleteDocument?id=' + id, { method: 'POST' })
                    .then(function(response) { return response.json(); })
                    .then(function(data) {
                        if (data.success) {
                            location.reload();
                        } else {
                            alert(data.message);
                        }
                    });
            }
        }

        // Initialize - show all on load
        document.addEventListener('DOMContentLoaded', function() {
            showAll();
        });
    </script>
}