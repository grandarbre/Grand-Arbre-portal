@model Grand_Arbre_portal.ViewModels.UserLoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Login - Grand Arbre</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #0F4C5C 0%, #1E6F7F 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .login-container {
            width: 100%;
            max-width: 450px;
        }

        .login-card {
            background: white;
            border-radius: 24px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
            overflow: hidden;
        }

        .login-header {
            background: linear-gradient(135deg, #0F4C5C 0%, #1E6F7F 100%);
            padding: 40px 30px;
            text-align: center;
        }

            .login-header i {
                font-size: 48px;
                color: #D4AF37;
                margin-bottom: 15px;
            }

            .login-header h2 {
                color: white;
                font-size: 28px;
                font-weight: 700;
                margin-bottom: 5px;
            }

            .login-header p {
                color: rgba(255, 255, 255, 0.8);
                font-size: 14px;
            }

        .login-body {
            padding: 40px 30px;
        }

        .form-group {
            margin-bottom: 25px;
        }

            .form-group label {
                display: block;
                margin-bottom: 8px;
                font-weight: 600;
                color: #0F4C5C;
                font-size: 14px;
            }

                .form-group label i {
                    margin-right: 8px;
                    color: #D4AF37;
                }

        .form-control {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid #e0e0e0;
            border-radius: 12px;
            font-size: 14px;
            transition: all 0.3s;
        }

            .form-control:focus {
                outline: none;
                border-color: #D4AF37;
                box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.1);
            }

        .btn-login {
            width: 100%;
            background: #D4AF37;
            color: #0F4C5C;
            font-weight: 700;
            font-size: 16px;
            padding: 12px;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s;
            margin-top: 10px;
        }

            .btn-login:hover {
                background: #B88A1A;
                color: white;
                transform: translateY(-2px);
            }

        .divider {
            text-align: center;
            margin: 25px 0;
            position: relative;
        }

            .divider::before {
                content: '';
                position: absolute;
                top: 50%;
                left: 0;
                right: 0;
                height: 1px;
                background: #e0e0e0;
            }

            .divider span {
                background: white;
                padding: 0 15px;
                position: relative;
                color: #999;
                font-size: 13px;
            }

        .login-footer {
            text-align: center;
            margin-top: 20px;
        }

            .login-footer a {
                color: #D4AF37;
                text-decoration: none;
                font-weight: 600;
                transition: all 0.3s;
            }

                .login-footer a:hover {
                    color: #B88A1A;
                    text-decoration: underline;
                }

        .alert {
            padding: 12px 15px;
            border-radius: 12px;
            margin-bottom: 20px;
            font-size: 14px;
        }

        .alert-danger {
            background: #fee;
            color: #c00;
            border: 1px solid #fcc;
        }

        .alert-info {
            background: #e8f4f8;
            color: #0F4C5C;
            border: 1px solid #b8e0f0;
        }

        .text-muted {
            color: #666;
            font-size: 12px;
        }

        .contact-buttons {
            display: flex;
            gap: 15px;
            justify-content: center;
            margin-top: 15px;
        }

        .contact-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 20px;
            background: #f0f4f8;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s;
            font-size: 14px;
        }

        .contact-btn-email {
            color: #0F4C5C;
        }

            .contact-btn-email:hover {
                background: #0F4C5C;
                color: white;
            }

        .contact-btn-phone {
            color: #1E6F7F;
        }

            .contact-btn-phone:hover {
                background: #1E6F7F;
                color: white;
            }

        .contact-btn i {
            font-size: 16px;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-card">
            <div class="login-header">
                <i class="fas fa-key"></i>
                <h2>User Login</h2>
                <p>Enter your email and access code to continue</p>
            </div>
            <div class="login-body">
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">
                        <i class="fas fa-exclamation-triangle"></i> @TempData["Error"]
                    </div>
                }

                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> Use the access code provided by your administrator.
                </div>

                <form asp-action="UserLogin" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="form-group">
                        <label for="Email">
                            <i class="fas fa-envelope"></i> Email Address
                        </label>
                        <input asp-for="Email" type="email" class="form-control"
                               placeholder="you@company.com" required />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label for="AccessCode">
                            <i class="fas fa-key"></i> Access Code
                        </label>
                        <input asp-for="AccessCode" type="text" class="form-control"
                               placeholder="Enter your access code" required />
                        <span asp-validation-for="AccessCode" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label class="checkbox-label">
                            <input asp-for="RememberMe" type="checkbox" style="margin-right: 8px;" />
                            <span>Remember me</span>
                        </label>
                    </div>

                    <button type="submit" class="btn-login">
                        <i class="fas fa-sign-in-alt"></i> Login
                    </button>
                </form>

                <div class="divider">
                    <span>Need help?</span>
                </div>

                <div class="login-footer">
                    <p><strong>Don't have an access code?</strong></p>
                    <div class="contact-buttons">
                        <a href="mailto:info@grandarbre.co.za?subject=Access%20Code%20Request&body=Hello,%20I%20need%20an%20access%20code%20to%20access%20the%20Grand%20Arbre%20portal.%20My%20email%20address%20is:%20" class="contact-btn contact-btn-email">
                            <i class="fas fa-envelope"></i> Email Admin
                        </a>
                        <a href="tel:+27813481947" class="contact-btn contact-btn-phone">
                            <i class="fas fa-phone-alt"></i> Call Admin
                        </a>
                    </div>
                    <p class="text-muted mt-3">
                        <i class="fas fa-shield-alt"></i> Secure portal for employees and clients
                    </p>
                </div>
            </div>
        </div>
    </div>
</body>
</html>