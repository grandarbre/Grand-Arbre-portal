@{
    ViewData["Title"] = "All Users - Admin";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-header" style="background: linear-gradient(135deg, #0F4C5C, #1E6F7F); color: white;">
            <h4><i class="fas fa-users"></i> All Users</h4>
            <p class="mb-0">View all user profiles</p>
        </div>
        <div class="card-body">
            <div class="mb-3">
                <input type="text" id="searchInput" class="form-control" placeholder="Search users..." />
            </div>
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th>Documents</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody id="usersList">
                        <tr><td colspan="6" class="text-center">Loading...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .btn-gold {
        background: #D4AF37;
        color: #0F4C5C;
        font-weight: bold;
        border: none;
        padding: 5px 15px;
        border-radius: 8px;
    }

        .btn-gold:hover {
            background: #B88A1A;
            color: white;
        }

    .badge-active {
        background: green;
        color: white;
        padding: 3px 10px;
        border-radius: 15px;
    }

    .badge-suspended {
        background: red;
        color: white;
        padding: 3px 10px;
        border-radius: 15px;
    }
</style>

<script>
    loadUsers();

    document.getElementById('searchInput').addEventListener('keyup', function() {
        var search = this.value.toLowerCase();
        var rows = document.querySelectorAll('#usersList tr');
        for (var i = 0; i < rows.length; i++) {
            var text = rows[i].innerText.toLowerCase();
            rows[i].style.display = text.includes(search) ? '' : 'none';
        }
    });

    function loadUsers() {
        fetch('/Admin/GetUsers')
            .then(function(response) { return response.json(); })
            .then(function(data) {
                var html = '';
                for (var i = 0; i < data.length; i++) {
                    var user = data[i];
                    var statusClass = user.isActive ? 'badge-active' : 'badge-suspended';
                    var statusText = user.isActive ? 'Active' : 'Suspended';
                    var roleIcon = user.role === 'Admin' ? '👑' : (user.role === 'Employee' ? '👔' : '👤');

                    html += '<tr>';
                    html += '<td><strong>' + escapeHtml(user.fullName) + '</strong><br><small>' + user.id.substring(0, 8) + '...</small></td>';
                    html += '<td>' + escapeHtml(user.email) + '</td>';
                    html += '<td>' + roleIcon + ' ' + user.role + '</td>';
                    html += '<td><span class="' + statusClass + '">' + statusText + '</span></td>';
                    html += '<td>' + (user.documentCount || 0) + '</td>';
                    html += '<td><a href="/Profile/ViewUser/' + user.id + '" class="btn btn-gold btn-sm">View Profile</a></td>';
                    html += '</tr>';
                }
                document.getElementById('usersList').innerHTML = html;
            });
    }

    function escapeHtml(str) {
        if (!str) return '';
        return str.replace(/[&<>]/g, function(m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        });
    }
</script>