@model Grand_Arbre_portal.Models.ApplicationUser
@{
    ViewData["Title"] = "My Profile";
    var role = ViewBag.Role as string ?? "None";
    var isAdmin = ViewBag.IsAdmin as bool? ?? false;
    var documentCount = ViewBag.DocumentCount as int? ?? 0;
    var downloadCount = ViewBag.DownloadCount as int? ?? 0;
    var profilePicture = ViewBag.ProfilePicturePath as string;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card">
                <div class="card-header" style="background: linear-gradient(135deg, #0F4C5C, #1E6F7F); color: white;">
                    <h4><i class="fas fa-user-circle"></i> My Profile</h4>
                </div>
                <div class="card-body text-center">
                    <!-- Profile Picture -->
                    <div class="mb-3 profile-picture-container">
                        <div class="profile-picture-wrapper">
                            @if (!string.IsNullOrEmpty(profilePicture))
                            {
                                <img src="@profilePicture" alt="Profile Picture" class="profile-picture" id="profileImage" />
                            }
                            else
                            {
                                <div class="profile-picture-placeholder" id="profileImage">
                                    <i class="fas fa-user" style="font-size: 60px; color: #D4AF37;"></i>
                                </div>
                            }

                            <!-- Upload Button -->
                            <button type="button" class="btn btn-gold btn-sm upload-btn" onclick="document.getElementById('fileInput').click()">
                                <i class="fas fa-camera"></i>
                            </button>
                            <input type="file" id="fileInput" style="display: none;" accept="image/*" onchange="uploadProfilePicture(this)" />
                        </div>
                        <div id="uploadStatus"></div>
                    </div>

                    <h4>@Model.FullName</h4>
                    <p class="text-muted">@Model.Email</p>
                    <div class="mb-2">
                        <span class="badge" style="background: #D4AF37; color: #0F4C5C; padding: 8px 15px;">
                            <i class="fas fa-tag"></i> @role
                        </span>
                    </div>
                    <hr />
                    <div class="row text-center">
                        <div class="col-6">
                            <h5>@documentCount</h5>
                            <p class="text-muted">Documents</p>
                        </div>
                        <div class="col-6">
                            <h5>@downloadCount</h5>
                            <p class="text-muted">Downloads</p>
                        </div>
                    </div>
                    <hr />
                    <div>
                        <span class="badge" style="background: #0F4C5C; color: white; padding: 5px 15px;">
                            <i class="fas fa-check-circle"></i> @(Model.IsActive ? "Active" : "Suspended")
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8 mb-4">
            <div class="card">
                <div class="card-header" style="background: linear-gradient(135deg, #0F4C5C, #1E6F7F); color: white;">
                    <h4><i class="fas fa-edit"></i> Edit Profile</h4>
                </div>
                <div class="card-body">
                    <form id="profileForm">
                        <div class="mb-3">
                            <label class="form-label">Full Name</label>
                            <input type="text" id="fullName" class="form-control" value="@Model.FullName" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email Address</label>
                            <input type="email" id="email" class="form-control" value="@Model.Email" disabled />
                            <small class="text-muted">Email cannot be changed</small>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Phone Number</label>
                            <input type="tel" id="phoneNumber" class="form-control" value="@Model.PhoneNumber" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Access Code</label>
                            <div class="input-group">
                                <input type="text" id="accessCode" class="form-control" value="@Model.AccessCode" disabled />
                                <button class="btn btn-gold" type="button" onclick="copyAccessCode()">
                                    <i class="fas fa-copy"></i> Copy
                                </button>
                            </div>
                            <small class="text-muted">Your access code for login</small>
                        </div>
                        <button type="submit" class="btn btn-gold">Save Changes</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .profile-picture-wrapper {
        position: relative;
        display: inline-block;
    }

    .profile-picture {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid #D4AF37;
        background: #f0f0f0;
    }

    .profile-picture-placeholder {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        background: linear-gradient(135deg, #0F4C5C, #1E6F7F);
        display: flex;
        align-items: center;
        justify-content: center;
        border: 4px solid #D4AF37;
    }

    .upload-btn {
        position: absolute;
        bottom: 5px;
        right: 5px;
        border-radius: 50%;
        width: 40px;
        height: 40px;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #D4AF37;
        color: #0F4C5C;
        border: 2px solid white;
    }

        .upload-btn:hover {
            background: #B88A1A;
            color: white;
        }

    .btn-gold {
        background: #D4AF37;
        color: #0F4C5C;
        font-weight: bold;
        border: none;
        padding: 8px 20px;
        border-radius: 8px;
        transition: all 0.3s;
    }

        .btn-gold:hover {
            background: #B88A1A;
            color: white;
        }

    .card {
        border: none;
        border-radius: 15px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.07);
    }

    .card-header {
        border-radius: 15px 15px 0 0 !important;
    }

    .form-control:focus {
        border-color: #D4AF37;
        box-shadow: 0 0 0 0.2rem rgba(212, 175, 55, 0.25);
    }

    .input-group .btn {
        border-radius: 0 8px 8px 0;
    }

    .badge {
        font-size: 14px;
        padding: 6px 12px;
    }

    #uploadStatus {
        margin-top: 10px;
        font-size: 14px;
    }
</style>

@section Scripts {
    <script>
        async function uploadProfilePicture(input) {
            if (input.files && input.files[0]) {
                var file = input.files[0];

                // Validate file type
                var allowedTypes = ['image/jpeg', 'image/png', 'image/jpg', 'image/gif'];
                if (!allowedTypes.includes(file.type)) {
                    alert('Only JPG, PNG, GIF images are allowed.');
                    input.value = '';
                    return;
                }

                // Validate file size (max 2MB)
                if (file.size > 2 * 1024 * 1024) {
                    alert('Image size must be less than 2MB.');
                    input.value = '';
                    return;
                }

                var formData = new FormData();
                formData.append('profilePicture', file);

                document.getElementById('uploadStatus').innerHTML = '<span class="text-info"><i class="fas fa-spinner fa-spin"></i> Uploading...</span>';

                try {
                    var response = await fetch('/Profile/UploadProfilePicture', {
                        method: 'POST',
                        body: formData
                    });

                    var result = await response.json();

                    if (result.success) {
                        // Reload page to show new picture
                        location.reload();
                    } else {
                        document.getElementById('uploadStatus').innerHTML = '<span class="text-danger">' + result.message + '</span>';
                    }
                } catch (error) {
                    document.getElementById('uploadStatus').innerHTML = '<span class="text-danger">Error uploading image.</span>';
                }
            }
        }

        document.getElementById('profileForm').addEventListener('submit', function(e) {
            e.preventDefault();

            var fullName = document.getElementById('fullName').value.trim();
            var phoneNumber = document.getElementById('phoneNumber').value.trim();

            if (!fullName) {
                alert('Please enter your full name');
                return;
            }

            var formData = new FormData();
            formData.append('fullName', fullName);
            formData.append('phoneNumber', phoneNumber);

            fetch('/Profile/UpdateProfile', { method: 'POST', body: formData })
                .then(function(response) { return response.json(); })
                .then(function(data) {
                    if (data.success) {
                        alert(data.message);
                        location.reload();
                    } else {
                        alert(data.message);
                    }
                });
        });

        function copyAccessCode() {
            var code = document.getElementById('accessCode').value;
            if (code) {
                navigator.clipboard.writeText(code);
                alert('Access code copied: ' + code);
            }
        }
    </script>
}
